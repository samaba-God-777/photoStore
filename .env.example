# Backend Server
PORT=5005
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/photo-store
# O usa MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/photo-store?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (para desarrollo local)
FRONTEND_URL=http://localhost:3000

# CORS Origins (para desarrollo)
# En producción, especifica dominios exactos
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration (opcional para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
